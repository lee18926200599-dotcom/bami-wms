    <select id="selectDetailListByUserId" resultMap="BaseResultMap">
        SELECT *
        FROM base_user_detail d1
        WHERE EXISTS
            (SELECT 1
             FROM base_user_detail d2
             WHERE d1.`user_id` = d2.`user_id`
               AND d2.`id` = #{userId})
          AND d1.`state` = 1
    </select>
