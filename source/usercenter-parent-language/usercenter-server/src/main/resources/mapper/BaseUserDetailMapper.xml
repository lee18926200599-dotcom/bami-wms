    <select id="findUserList" parameterType="com.usercenter.common.dto.UserDto"
            resultType="com.usercenter.server.entity.BaseUserInfo">
        select
        <include refid="base_detail_columns"/>
        from base_user_detail bud,base_user bu
        <where>
            bud.user_id = bu.id
        </where>
        <if test="likeQuery">
            <if test="userCode != null and userCode!='' ">
                AND bu.user_code LIKE CONCAT('%',#{userCode,jdbcType=VARCHAR},'%')
            </if>
            <if test="realName != null and realName!=''">
                AND bud.real_name LIKE CONCAT('%',#{realName,jdbcType=VARCHAR},'%')
            </if>
            <if test="userName != null and userName!='' ">
                AND bu.user_name LIKE CONCAT('%',#{userName,jdbcType=VARCHAR},'%')
            </if>
            <if test="phone != null and phone!='' ">
                AND bu.phone LIKE CONCAT('%',#{phone,jdbcType=VARCHAR},'%')
            </if>
            <if test="email != null and email!='' ">
                AND bu.email LIKE CONCAT('%',#{email,jdbcType=VARCHAR},'%')
            </if>
        </if>
        <if test="!likeQuery">
            <if test="userCode != null and userCode!='' ">
