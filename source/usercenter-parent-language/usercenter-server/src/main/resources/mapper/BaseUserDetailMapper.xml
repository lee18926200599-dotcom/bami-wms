        </if>
        <if test="state != null and state!=''">
            AND bud.state IN (#{state})
        </if>
        <if test="lockFlag != null and lockFlag!=''">
            AND bu.`lock_flag` IN (#{lockFlag})
        </if>
        <if test="deletedFlag != null">
