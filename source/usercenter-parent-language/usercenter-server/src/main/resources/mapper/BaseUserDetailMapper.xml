        </if>
        <if test="archivesId != null and archivesId!='' ">
            AND bud.archives_id IN (#{archivesId})
        </if>
        <if test="idSet != null">
            <foreach collection="idSet" index="index" item="item" open="and bud.id in (" separator="," close=")">
                #{item,jdbcType=BIGINT}
            </foreach>
        </if>
        <if test="idNotInSet != null">
            <foreach collection="idNotInSet" index="index" item="item" open="and bud.id not in (" separator=","
                     close=")">
                #{item,jdbcType=BIGINT}
            </foreach>
        </if>
        <if test="id != null and id!='' ">
            and bud.id = #{id,jdbcType=BIGINT}
        </if>
        <if test="condition!=null and condition!=''">
