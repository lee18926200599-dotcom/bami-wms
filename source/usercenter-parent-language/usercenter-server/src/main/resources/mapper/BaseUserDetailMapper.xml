    <sql id="detail_conditions">
        <where>
            bud.user_id = bu.id
            <if test="id!=null and id!=''">
                and bud.id = #{id}
            </if>
            <if test="groupId!=null and groupId!=''">
                and bud.group_id = #{groupId}
            </if>
            <if test="deletedFlag!=null">
                and bud.deleted_flag = #{deletedFlag}
            </if>
            <if test="userId!=null and userId!=''">
                and bud.user_id = #{userId}
            </if>
            <if test="userCode!=null and userCode!=''">
                and bu.user_code = #{userCode}
            </if>
            <if test="phone!=null and phone != ''">
                and bu.phone = #{phone}
            </if>
            <if test="userName!=null and userName != ''">
                and bu.user_name = #{userName}
            </if>
            <if test="email!=null and email != ''">
                and bu.email = #{email}
            </if>
            <if test="contactEmail!=null and contactEmail !=''">
                and bud.contact_email = #{contactEmail}
            </if>
            <if test="source!=null">
                and bud.source = #{source}
            </if>
            <if test="state!=null">
                and bud.state = #{state}
            </if>
            <if test="lockFlag!=null">
                and bud.`lock_flag` = #{lockFlag}
            </if>
            <if test="managerLevel!=null">
                and bud.`manager_level` = #{managerLevel}
            </if>
            <if test="orgIds!=null">
                <foreach collection="orgIds" item="orgId" open=" and bud.org_id in(" close=")" separator=",">
                    #{orgId}
                </foreach>
            </if>
            <if test="ids!=null">
                <foreach collection="ids" item="id" open=" and bud.id in(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>
            <if test="baseUserIds!=null">
                <foreach collection="baseUserIds" item="id" open=" and bu.id in(" close=")" separator=",">
                    #{id}
                </foreach>
            </if>
        </where>
    </sql>

    <sql id="extends_conditions">
        <if test="notEqualMap != null">
            <foreach item="item" index = "key" collection="notEqualMap" >
                <![CDATA[ and ${key} <> ${item} ]]>
            </foreach>
        </if>
        <if test="likeMap != null">
            <foreach item="item" index = "key" collection="likeMap" >
                <if test="item !=null and item != ''">
                    <![CDATA[ and ${key} like CONCAT('%',#{item},'%') ]]>
                </if>
            </foreach>
        </if>
        <if test="inMap != null">
            <foreach item="item" index = "key" collection="inMap" >
                <if test="item !=null">
                    and ${key} in
                    <foreach item="inItem" index="index" collection="item" open="(" separator="," close=")">
                        #{inItem}
                    </foreach>
                </if>
            </foreach>
        </if>
    </sql>
    <select id="selectAdministratorByQuery" resultType="com.usercenter.server.entity.BaseUserInfo"
            parameterType="com.usercenter.server.domain.vo.req.administratorsuser.AdministratorsQueryReq">
        select
        detail.id,
        bu.id as user_id,
        bu.email as contact_email,
        bu.phone,
        bu.user_name,
        bu.user_code,
        detail.manager_level,
        detail.state,
        bu.lock_flag,
        detail.remark,
        detail.org_id,
        detail.group_id
        from base_user bu join base_user_detail detail
        on bu.id = detail.user_id
        <where>
            detail.deleted_flag = 0
            <if test="groupId != null">
                and detail.group_id = #{groupId}
            </if>
            <if test="level != null">
                and detail.manager_level = #{level,jdbcType=INTEGER}
            </if>
            <if test="groupIds != null">
                and detail.group_id in
                <foreach collection="groupIds" item="group" open="(" close=")" separator=",">
                    #{group}
                </foreach>
            </if>
            <if test="userName != null and userName !=''">
                and bu.user_name LIKE CONCAT('%',#{userName,jdbcType=VARCHAR},'%')
            </if>
            <if test="userCode != null">
                and bu.user_code LIKE CONCAT('%',#{userCode,jdbcType=VARCHAR},'%')
            </if>
            <if test="phone != null">
                and bu.phone LIKE CONCAT('%',#{phone,jdbcType=VARCHAR},'%')
            </if>
            <if test="userName != null">
                and bu.user_name LIKE CONCAT('%',#{userName,jdbcType=VARCHAR},'%')
            </if>
        </where>
        GROUP BY
        detail.id,
        bu.id,bu.email,bu.phone,detail.user_name,
        detail.user_code,
        detail.manager_level,
        detail.state,
        detail.lock_flag,
        detail.remark
        order by detail.created_date desc
    </select>

