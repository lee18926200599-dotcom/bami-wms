    <select id="selectByLoginName" resultMap="BaseResultMap">
        select <include refid="Base_Column_List"/>
        from base_user
        where ( phone = #{loginName,jdbcType=VARCHAR}
        OR
        user_name= #{loginName,jdbcType=VARCHAR}
        OR
        email = #{loginName,jdbcType=VARCHAR})
        and exists (select 1 from base_user_detail where base_user.id = base_user_detail.user_id and base_user_detail.deleted_flag = 0)
        order by created_date desc
    </select>
    <select id="selectGlobalList" parameterType="com.usercenter.server.domain.vo.req.globaluser.GlobalUserReq" resultMap="base_users_with_details">
        select
        <include refid="Base_User_List"/>,
        <include refid="base_detail_columns"/>
        from base_user bu,base_user_detail detail
        where bu.id = detail.user_id and exists (select 1 from base_user_detail bud where bu.id = bud.user_id and bud.deleted_flag=0)
        <if test="userCode != null and userCode != ''">
            and bu.`user_code` like CONCAT('%',#{userCode},'%')
        </if>
        <if test="userName != null and userName != ''">
            and bu.`user_name` like CONCAT('%',#{userName},'%')
        </if>
        <if test="phone != null and phone != ''">
            and bu.`phone` like CONCAT("%",#{phone},"%")
        </if>
        <if test="email != null and email != ''">
            and bu.`email` like CONCAT("%",#{email},"%")
        </if>
        <if test="attribute != null">
            and bu.`attribute` = #{attribute}
        </if>
        <if test="lock != null">
            and bu.`lock_flag` = #{lock}
        </if>
        <if test="enable != null and enable == 0 ">
            and EXISTS (select 1 from base_user_detail bud1 where bu.id = bud1.user_id GROUP BY bud1.user_id HAVING AVG(bud1.`state`)=#{enable})
        </if>
        <if test="enable != null and  enable ==2">
            and EXISTS (select 1 from base_user_detail bud1 where bu.id = bud1.user_id GROUP BY bud1.user_id HAVING AVG(bud1.`state`)=#{enable})
        </if>
        <if test="enable != null and enable == 1">
            and detail.`state` = #{enable}
        </if>
        order by bu.id desc
    </select>
