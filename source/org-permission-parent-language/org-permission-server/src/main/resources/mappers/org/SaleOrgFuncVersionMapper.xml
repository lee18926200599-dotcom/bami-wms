<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.org.permission.server.org.mapper.SaleOrgFuncVersionMapper">
    <!--新版本销售组织职能-->
    <insert id="addSaleFunc" parameterType="com.org.permission.common.org.dto.func.SaleOrgFuncBean">
        insert into base_organization_function_version(<include refid="insert_base_list"/>)
        values(
        #{bean.id},
        4,
        #{bean.state},
        #{bean.orgId},
        #{reqParam.version},
        #{bean.parentSaleOrgId},
        #{bean.receiveOrgId},
        #{bean.settleOrgId},
        #{bean.stockOrgId},
        #{bean.createdBy},
        #{bean.createdDate},
        #{bean.modifiedBy},
        #{bean.modifiedDate},
        #{reqParam.versionFlag},
        #{reqParam.versionStartTime},
        #{reqParam.versionEndTime}
        )
    </insert>
    <sql id="insert_base_list">
        func_id,
        function_type,
        state,
        org_id,
        version,
        parent_sale_org_id,
        default_receive_org,
        default_settlement_org_id,
        default_stock_org_id,
        created_by,
        created_date,
        modified_by,
        modified_date,
        version_flag,
        version_start_time,
        version_end_time
    </sql>
</mapper>

