    <select id="queryBizsFunc" parameterType="com.org.permission.common.org.param.QueryBizsFuncParam"
            resultMap="organization_function_result_map">
        select
        id,
        function_type,
        org_id,
        (select org_name from base_organization where base_organization_function.org_id =base_organization.id)as
        orgName,
        default_pay_org_id,
        (select org_name from base_organization where base_organization_function.default_pay_org_id
        =base_organization.id)as defaultPayOrgName,
        default_settlement_org_id,
        (select org_name from base_organization where base_organization_function.default_settlement_org_id
        =base_organization.id)as defaultSettlementOrgName,
        default_stock_org_id,
        (select org_name from base_organization where base_organization_function.default_stock_org_id
        =base_organization.id)as defaultStockOrgName,
        default_receive_org_id,
        (select org_name from base_organization where base_organization_function.default_receive_org_id
        =base_organization.id)as defaultReceiveOrgName,
        default_account_org_id,
        (select org_name from base_organization where base_organization_function.default_account_org_id
        =base_organization.id)as defaultAccountOrgName,
        default_logistics_org_id,
        (select org_name from base_organization where base_organization_function.default_logistics_org_id
        =base_organization.id)as defaultLogisticsOrgName,
        created_by,
        created_date,
        modified_by,
        modified_date
        from base_organization_function where deleted_flag=0 and state=1
        <if test="reqParam.ids !=null and reqParam.ids.size>0">
            and org_id in (
            <foreach collection="reqParam.ids" item="item" separator=",">
                #{item}
            </foreach>
            )
        </if>
        <if test="reqParam.functionType !=null and reqParam.functionType !=0">
            and function_type =#{reqParam.functionType}
        </if>
    </select>

