        street_code,
        street_name,
        address,
        longitude,
        latitude,
        created_by,
        created_date
    </sql>


    <!--查询业务单元的组织职能-->
    <select id="queryOrgFunctionsByOrgId" parameterType="java.lang.Long" resultType="integer">
        SELECT function_type as functionType
        FROM base_organization_function
        WHERE org_id = #{buId}
          and deleted_flag=0
