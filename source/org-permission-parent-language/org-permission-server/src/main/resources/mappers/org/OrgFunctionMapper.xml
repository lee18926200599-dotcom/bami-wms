<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.org.permission.server.org.mapper.OrgFunctionMapper">

    <!--批量新增组织职能-->
    <insert id="batchAddOrganizationFunction" useGeneratedKeys="true" keyProperty="id">
        insert into base_organization_function(
        <include refid="insert_base_list"/>
        )
        values
        <foreach collection="list" item="bean" separator=",">
            (
            #{bean.id},
            #{bean.functionType},
            #{bean.orgId},
            #{bean.parentOrgId},
            #{bean.enterpriseCode},
            #{bean.enterpriseName},
            #{bean.taxpayerCode},
            #{bean.taxpayerName},
            #{bean.orgInstitutionCode},
            #{bean.bizRegistNumber},
            #{bean.state},
            #{bean.registeredCapital},
            #{bean.establishTime},
            #{bean.businessStartTime},
            #{bean.businessEndTime},
            #{bean.netAddress},
            #{bean.remark},
            #{bean.linker1},
            #{bean.phone1},
            #{bean.email1},
            #{bean.linker2},
            #{bean.phone2},
            #{bean.email2},
            #{bean.alone},
            #{bean.taxRegistrationNumber},
            #{bean.defaultPayOrgId},
            #{bean.defaultSettlementOrgId},
            #{bean.defaultStockOrgId},
            #{bean.higerSaleOrg},
            #{bean.defaultReceiveOrgId},
            #{bean.defaultAccountOrgId},
            #{bean.defaultLogisticsOrgId},
            #{bean.addressDetail.regionCode},
            #{bean.addressDetail.regionName},
            #{bean.addressDetail.invoiceProvCode},
            #{bean.addressDetail.invoiceProvName},
            #{bean.addressDetail.invoiceCityCode},
            #{bean.addressDetail.invoiceCityName},
            #{bean.addressDetail.invoiceDistrictCode},
            #{bean.addressDetail.invoiceDistrictName},
            #{bean.addressDetail.invoiceStreetCode},
            #{bean.addressDetail.invoiceStreetName},
            #{bean.addressDetail.address},
            #{bean.longitude},
            #{bean.latitude},
            #{bean.createdBy},
            #{bean.createdDate}
            )
        </foreach>
    </insert>

    <!--修改组织的所有组织职能-->
    <update id="modifyFuncStateByBUId">
        update base_organization_function
        set
        state = #{modifystate},
        modified_by = #{modifiedBy},
        modified_date=#{modifiedDate}
        where org_id = #{buId}
        <if test="sourceStates != null == sourceStates.size > 0">
          and state in (
            <foreach collection="sourceStates" item="state" separator=",">
                #{state}
            </foreach>
            )
        </if>
    </update>

    <!--根据 BU ID + 职能类型 删除组织职能-->
    <update id="delOrgFuncByOrgIdAndFuncTypes">
        update base_organization_function set
        deleted_flag = 1 ,
        modified_by = #{modifiedBy},
        modified_date=#{modifiedDate}
        where org_id = #{orgId} and function_type in (
        <foreach collection="funcTypes" separator="," item="funcType">
            #{funcType}
        </foreach>
        )
    </update>

    <sql id="insert_base_list">
        id,
        function_type,
        org_id,
        parent_org_id,
        enterprise_code,
        enterprise_name,
