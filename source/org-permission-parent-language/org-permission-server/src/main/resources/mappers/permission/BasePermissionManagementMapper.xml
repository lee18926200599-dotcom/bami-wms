<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.org.permission.server.permission.mapper.BasePermissionManagementMapper">

    <resultMap type="com.org.permission.server.permission.entity.BasePermissionManagement" id="base_permission_managements">
        <id column="id" jdbcType="INTEGER" property="id" />
        <result column="name" jdbcType="VARCHAR" property="name" />
        <result column="des" jdbcType="VARCHAR" property="des" />
        <result column="remark" jdbcType="VARCHAR" property="remark" />
        <result column="state" jdbcType="INTEGER" property="state" />
        <result column="created_by" jdbcType="BIGINT" property="createdBy" />
        <result column="created_name" jdbcType="VARCHAR" property="createdName" />
        <result column="created_date" jdbcType="TIMESTAMP" property="createdDate" />
        <result column="modified_by" jdbcType="BIGINT" property="modifiedBy" />
        <result column="modified_name" jdbcType="VARCHAR" property="modifiedName" />
        <result column="modified_date" jdbcType="TIMESTAMP" property="modifiedDate" />
    </resultMap>

    <insert id="addBasePermissionManagement" parameterType="com.org.permission.server.permission.entity.BasePermissionManagement" useGeneratedKeys="true" keyProperty="id" >
        insert into
            base_permission_management(id,name,des,remark,state,created_by,created_name,created_date,modified_by,modified_name,modified_date)
        values( #{id,jdbcType=INTEGER},#{name,jdbcType=VARCHAR},#{des,jdbcType=VARCHAR},#{remark,jdbcType=VARCHAR},#{state,jdbcType=INTEGER},#{createdBy,jdbcType=BIGINT},#{createdName,jdbcType=VARCHAR},#{createdDate,jdbcType=TIMESTAMP},#{modifiedBy,jdbcType=BIGINT},#{modifiedName,jdbcType=VARCHAR},#{modifiedDate,jdbcType=TIMESTAMP})
    </insert>
    <update id="delBasePermissionManagement" parameterType="java.lang.Long">
        update  base_permission_management set state='0' where id=#{id}
    </update>
    <delete id="delBasePermissionManagementTrue"  parameterType="java.lang.Long">
        delete from base_permission_management where id=#{id}
    </delete>
    <update id="updateBasePermissionManagement" parameterType="com.org.permission.server.permission.entity.BasePermissionManagement">
        update base_permission_management
        <set>
            <if test="name!=null">
                name=#{name,jdbcType=VARCHAR},
            </if>
            <if test="des!=null">
                des=#{des,jdbcType=VARCHAR},
            </if>
            <if test="remark!=null">
                remark=#{remark,jdbcType=VARCHAR},
            </if>
            <if test="state!=null">
                state=#{state,jdbcType=INTEGER},
            </if>
            <if test="createdBy!=null">
                created_by=#{createdBy,jdbcType=BIGINT},
            </if>
            <if test="createdName!=null">
                created_name=#{createdName,jdbcType=VARCHAR},
            </if>
            <if test="createdDate!=null">
                created_date=#{createdDate,jdbcType=TIMESTAMP},
            </if>
            <if test="modifiedBy!=null">
                modified_by=#{modifiedBy,jdbcType=BIGINT},
            </if>
            <if test="modifiedName!=null">
                modified_name=#{modifiedName,jdbcType=VARCHAR},
            </if>
            <if test="modifiedDate!=null">
                modified_date=#{modifiedDate,jdbcType=TIMESTAMP}
            </if>
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>
    <select id="getBasePermissionManagementByID" parameterType="java.lang.Long" resultMap="base_permission_managements">
        select * from base_permission_management where   id=#{id}
    </select>
    <select id="getBasePermissionManagementCount" resultType="Integer">
        select count('1') from base_permission_management where state='1'
    </select>
    <select id="getBasePermissionManagementCountAll" parameterType="String" resultMap="base_permission_managements">
        select count('1') from base_permission_management
    </select>
    <select id="getListBasePermissionManagementsByPage" parameterType="com.org.permission.server.permission.vo.BasePermissionManagementVo" resultMap="base_permission_managements">
        select * from base_permission_management
        <include refid="Where_Conditions"/>
    </select>
    <select id="getListBasePermissionManagementsByPOJO" parameterType="com.org.permission.server.permission.entity.BasePermissionManagement" resultMap="base_permission_managements">
        select * from base_permission_management
        <include refid="Where_Conditions"/>
    </select>
    <select id="getListBasePermissionManagementsByPojoPage" parameterType="java.util.Map"  resultMap="base_permission_managements">
        select * from base_permission_management where 1=1
        <if test="pojo.id != null and pojo.id != ''"> and id = #{pojo.id}</if>
        <if test="pojo.name != null and pojo.name != ''"> and name = #{pojo.name}</if>
        <if test="pojo.des != null and pojo.des != ''"> and des = #{pojo.des}</if>
        <if test="pojo.remark != null and pojo.remark != ''"> and remark = #{pojo.remark}</if>
        <if test="pojo.state != null and pojo.state != ''"> and state = #{pojo.state}</if>
    </select>
    <sql id="Where_Conditions">
        <where>
            <!-- 以下查询条件为模拟生成，请大家开发时进行修改-->
            <if test="name!=null">
                and name=#{name,jdbcType=VARCHAR}
            </if>
            <if test="des!=null">
                and des=#{des,jdbcType=VARCHAR}
            </if>
            <if test="remark!=null">
                and remark=#{remark,jdbcType=VARCHAR}
            </if>
            <if test="state!=null">
                and state=#{state,jdbcType=INTEGER}
            </if>
            <if test="createdBy!=null">
                and created_by=#{createdBy,jdbcType=BIGINT}
            </if>
            <if test="createdName!=null">
                and created_name=#{createdName,jdbcType=VARCHAR}
            </if>
            <if test="createdDate!=null">
                and created_date=#{createdDate,jdbcType=TIMESTAMP}
            </if>
            <if test="modifiedBy!=null">
                and modified_by=#{modifiedBy,jdbcType=BIGINT}
            </if>
            <if test="modifiedName!=null">
                and modified_name=#{modifiedName,jdbcType=VARCHAR}
            </if>
            <if test="modifiedDate!=null">
                and modified_date=#{modifiedDate,jdbcType=TIMESTAMP}
            </if>
        </where>
    </sql>
</mapper>

