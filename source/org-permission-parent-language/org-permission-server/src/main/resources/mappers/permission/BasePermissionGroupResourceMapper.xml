<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.org.permission.server.permission.mapper.BasePermissionGroupResourceMapper">

    <resultMap type="com.org.permission.server.permission.entity.BasePermissionGroupResource"
               id="base_permission_group_resources">
        <id column="id" jdbcType="BIGINT" property="id"/>
        <result column="group_id" jdbcType="BIGINT" property="groupId"/>
        <result column="permission_id" jdbcType="INTEGER" property="permissionId"/>
        <result column="state" jdbcType="INTEGER" property="state"/>
        <result column="created_by" jdbcType="BIGINT" property="createdBy"/>
        <result column="created_name" jdbcType="VARCHAR" property="createdName"/>
        <result column="created_date" jdbcType="TIMESTAMP" property="createdDate"/>
        <result column="modified_by" jdbcType="BIGINT" property="modifiedBy"/>
        <result column="modified_name" jdbcType="VARCHAR" property="modifiedName"/>
        <result column="modified_date" jdbcType="TIMESTAMP" property="modifiedDate"/>
    </resultMap>

    <insert id="addBasePermissionGroupResource"
            parameterType="com.org.permission.server.permission.entity.BasePermissionGroupResource" useGeneratedKeys="true"
            keyProperty="id">
        insert into base_permission_group_resource(id, group_id, permission_id, state, created_by, created_name,
                                                   created_date, modified_by, modified_name, modified_date)
        values (#{id,jdbcType=INTEGER}, #{groupId,jdbcType=BIGINT}, #{permissionId,jdbcType=INTEGER},
                #{state,jdbcType=INTEGER}, #{createdBy,jdbcType=BIGINT}, #{createdName,jdbcType=VARCHAR},
                #{createdDate,jdbcType=TIMESTAMP}, #{modifiedBy,jdbcType=BIGINT}, #{modifiedName,jdbcType=VARCHAR},
                #{modifiedDate,jdbcType=TIMESTAMP})
    </insert>
    <update id="delBasePermissionGroupResource" parameterType="java.lang.Long">
        update base_permission_group_resource
        set state='0'
        where id = #{id}
    </update>
    <delete id="delBasePermissionGroupResourceTrue" parameterType="java.lang.Long">
        delete
        from base_permission_group_resource
        where id = #{id}
    </delete>
    <update id="updateBasePermissionGroupResource"
            parameterType="com.org.permission.server.permission.entity.BasePermissionGroupResource">
        update base_permission_group_resource
        <set>
            <if test="groupId!=null">
                group_id=#{groupId,jdbcType=BIGINT},
            </if>
            <if test="permissionId!=null">
                permission_id=#{permissionId,jdbcType=INTEGER},
            </if>
            <if test="state!=null">
                state=#{state,jdbcType=INTEGER},
            </if>
            <if test="createdBy!=null">
                created_by=#{createdBy,jdbcType=BIGINT},
            </if>
            <if test="createdName!=null">
                created_name=#{createdName,jdbcType=VARCHAR},
            </if>
            <if test="createdDate!=null">
                created_date=#{createdDate,jdbcType=TIMESTAMP},
            </if>
            <if test="modifiedBy!=null">
                modified_by=#{modifiedBy,jdbcType=BIGINT},
            </if>
            <if test="modifiedName!=null">
                modified_name=#{modifiedName,jdbcType=VARCHAR},
            </if>
            <if test="modifiedDate!=null">
                modified_date=#{modifiedDate,jdbcType=TIMESTAMP}
            </if>
        </set>
        where id = #{id,jdbcType=INTEGER}
    </update>
    <select id="getBasePermissionGroupResourceByID" parameterType="java.lang.Long" resultMap="base_permission_group_resources">
        select *
        from base_permission_group_resource
        where id = #{id}
    </select>
    <select id="getBasePermissionGroupResourceCount" resultType="Integer">
        select count('1')
        from base_permission_group_resource
        where state = '1'
    </select>
    <select id="getBasePermissionGroupResourceCountAll" parameterType="String"
            resultMap="base_permission_group_resources">
        select count('1')
        from base_permission_group_resource
    </select>
    <select id="getListBasePermissionGroupResourcesByPage"
            parameterType="com.org.permission.server.permission.vo.BasePermissionGroupResourceVo"
            resultMap="base_permission_group_resources">
        select * from base_permission_group_resource
        <include refid="Where_Conditions"/>
    </select>
    <select id="getListBasePermissionGroupResourcesByPOJO"
            parameterType="com.org.permission.server.permission.entity.BasePermissionGroupResource"
            resultMap="base_permission_group_resources">
        select * from base_permission_group_resource
        <include refid="Where_Conditions"/>
    </select>
    <select id="getListBasePermissionGroupResourcesByPojoPage" parameterType="java.util.Map"
            resultMap="base_permission_group_resources">
        select * from base_permission_group_resource where 1=1
        <if test="pojo.id != null and pojo.id != ''">and id = #{pojo.id}</if>
        <if test="pojo.groupId != null and pojo.groupId != ''">and group_id = #{pojo.groupId}</if>
        <if test="pojo.permissionId != null and pojo.permissionId != ''">and permission_id = #{pojo.permissionId}</if>
        <if test="pojo.state != null and pojo.state != ''">and state = #{pojo.state}</if>
    </select>
    <sql id="Where_Conditions">
        <where>
            <!-- 以下查询条件为模拟生成，请大家开发时进行修改-->
            <if test="id != null  ">and id = #{id}</if>
            <if test="groupId!=null">
                and group_id=#{groupId,jdbcType=BIGINT}
            </if>
            <if test="permissionId!=null">
                and permission_id=#{permissionId,jdbcType=INTEGER}
            </if>
            <if test="state!=null">
                and state=#{state,jdbcType=INTEGER}
            </if>
            <if test="createdBy!=null">
                and created_by=#{createdBy,jdbcType=BIGINT}
            </if>
            <if test="createdName!=null">
                and created_name=#{createdName,jdbcType=VARCHAR}
            </if>
            <if test="createdDate!=null">
                and created_date=#{createdDate,jdbcType=TIMESTAMP}
            </if>
            <if test="modifiedBy!=null">
                and modified_by=#{modifiedBy,jdbcType=BIGINT}
            </if>
            <if test="modifiedName!=null">
                and modified_name=#{modifiedName,jdbcType=VARCHAR}
            </if>
            <if test="modifiedDate!=null">
                and modified_date=#{modifiedDate,jdbcType=TIMESTAMP}
            </if>
        </where>
    </sql>
</mapper>

