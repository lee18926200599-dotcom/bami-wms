<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.org.permission.server.permission.mapper.BasePermissionGroupDataMapper">

    <resultMap type="com.org.permission.server.permission.entity.BasePermissionGroupData" id="base_permission_group_datas">
        <id column="id" jdbcType="INTEGER" property="id"/>
        <result column="group_id" jdbcType="BIGINT" property="groupId"/>
        <result column="data_id" jdbcType="BIGINT" property="dataId"/>
        <result column="state" jdbcType="INTEGER" property="state"/>
        <result column="created_by" jdbcType="BIGINT" property="createdBy"/>
        <result column="created_name" jdbcType="VARCHAR" property="createdName"/>
        <result column="created_date" jdbcType="TIMESTAMP" property="createdDate"/>
        <result column="modified_by" jdbcType="BIGINT" property="modifiedBy"/>
        <result column="modified_name" jdbcType="VARCHAR" property="modifiedName"/>
        <result column="modified_date" jdbcType="TIMESTAMP" property="modifiedDate"/>
    </resultMap>

    <insert id="addBasePermissionGroupData" parameterType="com.org.permission.server.permission.entity.BasePermissionGroupData"
            useGeneratedKeys="true" keyProperty="id">
        insert into base_permission_group_data(id, group_id, data_id, state, created_by, created_name, created_date,
                                               modified_by, modified_name, modified_date)
        values (#{id,jdbcType=INTEGER}, #{groupId,jdbcType=BIGINT}, #{dataId,jdbcType=BIGINT},
                #{state,jdbcType=INTEGER}, #{createdBy,jdbcType=BIGINT}, #{createdName,jdbcType=VARCHAR},
                #{createdDate,jdbcType=TIMESTAMP}, #{modifiedBy,jdbcType=BIGINT}, #{modifiedName,jdbcType=VARCHAR},
                #{modifiedDate,jdbcType=TIMESTAMP})
    </insert>
    <update id="delBasePermissionGroupData" parameterType="java.lang.Long">
        update base_permission_group_data
        set state='0'
        where id = #{id}
    </update>
    <delete id="delBasePermissionGroupDataTrue" parameterType="java.lang.Long">
        delete
        from base_permission_group_data
        where id = #{id}
    </delete>
    <update id="updateBasePermissionGroupData"
            parameterType="com.org.permission.server.permission.entity.BasePermissionGroupData">
        update base_permission_group_data
        <trim prefix="set" suffixOverrides=",">
            <if test="id != null  ">id = #{id},</if>
            <if test="groupId != null  ">group_id = #{groupId},</if>
            <if test="dataId != null  ">data_id = #{dataId},</if>
            <if test="state != null  ">state = #{state},</if>
        </trim>
        where id=#{id}
    </update>
    <select id="getBasePermissionGroupDataByID" parameterType="java.lang.Long" resultMap="base_permission_group_datas">
        select *
        from base_permission_group_data
        where id = #{id}
    </select>
    <select id="getBasePermissionGroupDataCount" resultType="Integer">
        select count('1')
        from base_permission_group_data
        where state = '1'
    </select>
    <select id="getBasePermissionGroupDataCountAll" parameterType="String" resultMap="base_permission_group_datas">
        select count('1')
        from base_permission_group_data
    </select>
    <select id="getListBasePermissionGroupDatasByPage"
            parameterType="com.org.permission.server.permission.vo.BasePermissionGroupDataVo"
            resultMap="base_permission_group_datas">
        select * from base_permission_group_data
        <include refid="Where_Conditions"/>
    </select>
    <select id="getListBasePermissionGroupDatasByPOJO"
            parameterType="com.org.permission.server.permission.entity.BasePermissionGroupData"
            resultMap="base_permission_group_datas">
        select * from base_permission_group_data
        <include refid="Where_Conditions"/>
    </select>
    <select id="getListBasePermissionGroupDatasByPojoPage" parameterType="java.util.Map"
            resultMap="base_permission_group_datas">
        select * from base_permission_group_data where 1=1
        <if test="pojo.id != null and pojo.id != ''">and id = #{pojo.id}</if>
        <if test="pojo.groupId != null and pojo.groupId != ''">and group_id = #{pojo.groupId}</if>
        <if test="pojo.dataId != null and pojo.dataId != ''">and data_id = #{pojo.dataId}</if>
        <if test="pojo.state != null and pojo.state != ''">and state = #{pojo.state}</if>
    </select>
    <sql id="Where_Conditions">
        <where>
            <!-- 以下查询条件为模拟生成，请大家开发时进行修改-->
            <if test="id != null  ">and id = #{id}</if>
            <if test="groupId!=null">
                and group_id=#{groupId,jdbcType=BIGINT}
            </if>
            <if test="dataId!=null">
                and data_id=#{dataId,jdbcType=BIGINT}
            </if>
            <if test="state!=null">
                and state=#{state,jdbcType=INTEGER}
            </if>
            <if test="createdBy!=null">
                and created_by=#{createdBy,jdbcType=BIGINT}
            </if>
            <if test="createdName!=null">
                and created_name=#{createdName,jdbcType=VARCHAR}
            </if>
            <if test="createdDate!=null">
                and created_date=#{createdDate,jdbcType=TIMESTAMP}
            </if>
            <if test="modifiedBy!=null">
                and modified_by=#{modifiedBy,jdbcType=BIGINT}
            </if>
            <if test="modifiedName!=null">
                and modified_name=#{modifiedName,jdbcType=VARCHAR}
            </if>
            <if test="modifiedDate!=null">
                and modified_date=#{modifiedDate,jdbcType=TIMESTAMP}
            </if>
        </where>
    </sql>
</mapper>

